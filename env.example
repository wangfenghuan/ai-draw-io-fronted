# Backend API Configuration
# NEXT_PUBLIC_API_BASE_URL: Backend API base URL (default: /api via rewrites)
NEXT_PUBLIC_API_BASE_URL=/api

# WebSocket URL (collaboration feature)
NEXT_PUBLIC_WS_URL=ws://localhost:8081/api/yjs

# Draw.io Configuration (Optional)
# NEXT_PUBLIC_DRAWIO_BASE_URL=https://embed.diagrams.net

# PDF Input Feature (Optional)
# Enable PDF file upload to extract text and generate diagrams
# ENABLE_PDF_INPUT=true
# NEXT_PUBLIC_MAX_EXTRACTED_CHARS=150000